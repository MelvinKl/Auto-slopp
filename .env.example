# =============================================================================
# ⚠️⚠️⚠️ IMPORTANT: GITHUB TOKEN SECURITY WARNING ⚠️⚠️⚠️
# =============================================================================
#
# DO NOT ADD GH_TOKEN OR GITHUB_TOKEN TO THE .env FILE!
#
# Putting your GitHub token in .env is a SECURITY RISK because:
# - CLI tools spawned by auto-slopp will read the .env file
# - These tools could gain unauthorized access to your GitHub account
#
# INSTEAD: Create a separate .gh.env file OUTSIDE this project:
#   cat > ~/.gh.env <<EOF
#   GH_TOKEN=ghp_your_github_personal_access_token
#   EOF
#
# And ONLY source it when manually using the gh CLI:
#   source ~/.gh.env && gh repo list
#
# See README.md "Configure your GitHub token" section for details.
#
# =============================================================================

# Auto-slopp Environment Configuration Template
# Copy this file to .env and customize the values for your environment

# ================================================================================
# GITHUB AUTHENTICATION
# ================================================================================

# ⚠️ WARNING: Do NOT set GH_TOKEN or GITHUB_TOKEN in .env
# Do NOT set these as environment variables.
# This prevents CLI tools from interacting with GitHub directly.

# =============================================================================
# CORE PATH CONFIGURATION
# =============================================================================

# Base path to the repository directory (default: current working directory)
# Example: /home/user/my-repo
AUTO_SLOPP_BASE_REPO_PATH=/path/to/your/repository

# Comma-separated list of disabled workers (default: none, all workers enabled)
# Available workers: GitHubIssueWorker, PRWorker, StaleBranchCleanupWorker, UpdatePRBranchesWorker
# Example: AUTO_SLOPP_WORKERS_DISABLED='["GitHubIssueWorker"]'
AUTO_SLOPP_WORKERS_DISABLED='[]'

# =============================================================================
# EXECUTOR CONFIGURATION
# =============================================================================

# Sleep interval between executor iterations in seconds (default: 1.0)
# Controls how frequently the executor scans for and runs workers
AUTO_SLOPP_EXECUTOR_SLEEP_INTERVAL=1.0

# Enable debug mode with verbose logging (default: False)
# Set to 'true' or '1' to enable debug logging
AUTO_SLOPP_DEBUG=false

# Slopmachine preset to select pre-defined CLI settings (default: opencode)
# Available values: opencode, codex, claude, gemini
AUTO_SLOPP_SLOPMACHINE=codex

# Timeout for slopmachine execution in seconds (default: 7200, 2 hours)
# Controls how long the CLI tool is allowed to run before timing out
AUTO_SLOPP_SLOP_TIMEOUT=7200

# =============================================================================
# STALE BRANCH CLEANUP WORKER CONFIGURATION
# =============================================================================

# Days after which a local branch without remote is considered stale and deleted (default: 1)
AUTO_SLOPP_STALE_BRANCH_DAYS_THRESHOLD=1

# =============================================================================
# GITHUB ISSUE WORKER CONFIGURATION
# =============================================================================

# Required label for GitHubIssueWorker to process an issue (default: ai)
# Only issues with this label will be processed, unless created by allowed_creator
AUTO_SLOPP_GITHUB_ISSUE_WORKER_REQUIRED_LABEL=ai

# Allowed GitHub username for GitHubIssueWorker (default: MelvinKl)
# Issues created by this user will be processed even without the required label
AUTO_SLOPP_GITHUB_ISSUE_WORKER_ALLOWED_CREATOR=MelvinKl

# Optional CLI overrides (leave commented out to use slopmachine preset defaults)
# AUTO_SLOPP_CLI_COMMAND=opencode
# AUTO_SLOPP_CLI_ARGS='["--agent", "openagent", "run"]'

# =============================================================================
# TELEGRAM LOGGING INTEGRATION
# =============================================================================

# Enable Telegram logging integration (default: False)
# Set to 'true' or '1' to send log messages to Telegram
AUTO_SLOPP_TELEGRAM_ENABLED=false

# Telegram bot token for API authentication (required if Telegram enabled)
# Get this from @BotFather on Telegram
# Example: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
AUTO_SLOPP_TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram chat ID to send messages to (required if Telegram enabled)
# Can be a personal chat ID or group chat ID
# Example: 123456789 or -1001234567890
AUTO_SLOPP_TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram API request timeout in seconds (default: 30.0)
# How long to wait for Telegram API responses
AUTO_SLOPP_TELEGRAM_TIMEOUT=30.0

# Number of retry attempts for failed Telegram requests (default: 3)
# How many times to retry failed API calls
AUTO_SLOPP_TELEGRAM_RETRY_ATTEMPTS=3

# Delay between retry attempts in seconds (default: 1.0)
# Time to wait between retry attempts
AUTO_SLOPP_TELEGRAM_RETRY_DELAY=1.0

# Message parse mode for Telegram (default: HTML)
# Options: HTML, Markdown, or None/disabled
# HTML formatting: <b>bold</b>, <i>italic</i>, <code>code</code>
# Markdown formatting: *bold*, _italic_, `code`
AUTO_SLOPP_TELEGRAM_PARSE_MODE=HTML

# Disable web page preview in Telegram messages (default: True)
# Set to 'false' to enable link previews in messages
AUTO_SLOPP_TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true

# Disable notification sound for Telegram messages (default: False)
# Set to 'true' to send messages silently
AUTO_SLOPP_TELEGRAM_DISABLE_NOTIFICATION=false

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================

# 1. Get a Telegram Bot Token:
#    - Open Telegram and search for @BotFather
#    - Send /newbot and follow the instructions
#    - Copy the bot token and paste it above
#
# 2. Get Your Chat ID:
#    - Send a message to your new bot
#    - Visit: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#    - Look for "chat":{"id":123456789} in the response
#    - Copy the chat ID and paste it above
#
# 3. Test Your Setup:
#    - Enable Telegram logging: AUTO_SLOPP_TELEGRAM_ENABLED=true
#    - Run: auto-slopp --debug
#    - You should receive a test message in Telegram
#
# 4. Custom Worker Development:
#    - Workers are explicitly imported in the workers package
#    - Implement classes that inherit from Worker base class
#    - Implement the run() method with your automation logic
#    - Enable/disable workers using AUTO_SLOPP_WORKERS_DISABLED
#
# =============================================================================
# EXAMPLE VALUES FOR TESTING
# =============================================================================

# Uncomment and modify these values for quick testing:
#
# AUTO_SLOPP_BASE_REPO_PATH=/tmp/test-repo
# AUTO_SLOPP_WORKERS_DISABLED='["GitHubIssueWorker"]'
# AUTO_SLOPP_DEBUG=true
# AUTO_SLOPP_TELEGRAM_ENABLED=true
# AUTO_SLOPP_TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# AUTO_SLOPP_TELEGRAM_CHAT_ID=123456789
# AUTO_SLOPP_EXECUTOR_SLEEP_INTERVAL=5.0
